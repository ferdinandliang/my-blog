---
const { title = "我的博客" } = Astro.props;
---

<header>
  <nav>
    <a href="/" class="logo">{title}</a>
    <div class="nav-links">
      <a href="/">文章</a>
      <a href="/about">关于</a>
    </div>
  </nav>
</header>

<style>
  header {
    padding: var(--spacing-lg) 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-xl);
  }
  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-md);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
    text-decoration: none;
  }
  .logo:hover {
    color: var(--color-text);
    opacity: 0.7;
  }
  .nav-links {
    display: flex;
    gap: var(--spacing-md);
  }
  .nav-links a {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    text-decoration: none;
  }
  .nav-links a:hover {
    color: var(--color-text);
  }
</style>
